{
  "name": "kobedb",
  "version": "0.1.0",
  "private": true,
  "description": "KobeDB — a self-hostable, open-source backend platform (a Supabase-style stack) with Postgres, auto REST API, Auth, Realtime, Storage and a Studio dashboard.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "dev": "npm run dev --workspace @kobedb/server",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace @kobedb/server",
    "client:build": "npm run build --workspace @kobedb/client"
  },
  "engines": {
    "node": ">=20"
  }
}
