# ── KobeDB configuration ────────────────────────────────────────────────
# Copy to `.env` and adjust. Never commit your real .env.

# HTTP server
PORT=8000
HOST=0.0.0.0
# Public URL the Studio dashboard and clients use to reach the API.
PUBLIC_URL=http://localhost:8000

# Postgres connection
DATABASE_URL=postgres://kobedb:kobedb@localhost:5432/kobedb

# JWT signing secret (CHANGE THIS — at least 32 random chars in production)
JWT_SECRET=super-secret-change-me-please-32-chars-min
# Access token lifetime (seconds) and refresh token lifetime (seconds)
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# A long-lived service-role key for trusted server-side access (bypasses RLS-style checks).
SERVICE_ROLE_KEY=service-role-change-me

# Storage backend: where uploaded objects are written on disk.
STORAGE_PATH=./storage-data

# Studio dashboard admin (basic gate for the dashboard UI).
STUDIO_ENABLED=true
