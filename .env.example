# ── KobeDB configuration ────────────────────────────────────────────────
# Copy to `.env` and adjust. Never commit your real .env.

# HTTP server
PORT=8000
HOST=0.0.0.0
# Public URL the Studio dashboard and clients use to reach the API.
PUBLIC_URL=http://localhost:8000

# Postgres connection
DATABASE_URL=postgres://kobedb:kobedb@localhost:5432/kobedb

# JWT signing secret (CHANGE THIS — at least 32 random chars in production)
JWT_SECRET=super-secret-change-me-please-32-chars-min
# Access token lifetime (seconds) and refresh token lifetime (seconds)
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# A long-lived service-role key for trusted server-side access (bypasses RLS-style checks).
SERVICE_ROLE_KEY=service-role-change-me

# Storage backend: 'local' (filesystem) or 's3' (S3-compatible).
STORAGE_BACKEND=local
STORAGE_PATH=./storage-data
# S3 settings (only used when STORAGE_BACKEND=s3; works with AWS S3, MinIO, R2, …)
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=
S3_FORCE_PATH_STYLE=true

# Database backups: directory where pg_dump archives are written.
BACKUP_DIR=./backups

# Edge functions: handlers dir, per-invocation timeout, and runtime selection.
FUNCTIONS_PATH=./functions
FUNCTION_TIMEOUT_MS=10000
# 'auto' uses Deno if installed, else Node worker threads. Force with 'deno' or 'worker'.
FUNCTIONS_RUNTIME=auto

# OAuth providers (optional). Leave blank to disable a provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email delivery for magic links: 'log' (default: prints link to console), 'smtp', or 'resend'.
EMAIL_PROVIDER=log
EMAIL_FROM=KobeDB <no-reply@kobedb.local>
# SMTP settings (EMAIL_PROVIDER=smtp) — works with Gmail, SendGrid SMTP, Mailgun, Postmark, …
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Resend API (EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# Studio dashboard admin (basic gate for the dashboard UI).
STUDIO_ENABLED=true
